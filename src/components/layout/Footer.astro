---
const currentYear = new Date().getFullYear();

const footerColumns = [
  {
    label: 'Tools',
    links: [
      { label: 'Text Formatter', href: '/linkedin-text-formatter/' },
      { label: 'Post Preview', href: '/linkedin-post-preview/' },
      { label: 'Character Counter', href: '/linkedin-character-counter/' },
      { label: 'Headline Analyzer', href: '/linkedin-headline-analyzer/' },
      { label: 'Hashtag Generator', href: '/linkedin-hashtag-generator/' },
      { label: 'Emoji Adder', href: '/linkedin-emoji-adder/' },
    ],
  },
  {
    label: 'Templates',
    links: [
      { label: 'Connection Messages', href: '/linkedin-connection-message-templates/' },
      { label: 'About Section', href: '/linkedin-about-section-templates/' },
      { label: 'All Templates', href: '/templates/' },
    ],
  },
  {
    label: 'Guides',
    links: [
      { label: 'Post Formatting', href: '/guides/linkedin-post-formatting/' },
      { label: 'Headline Examples', href: '/guides/linkedin-headline-examples/' },
      { label: 'All Guides', href: '/guides/' },
    ],
  },
  {
    label: 'Company',
    links: [
      { label: 'About Us', href: '/about-us/' },
      { label: 'Contact Us', href: '/contact-us/' },
      { label: 'Resources', href: '/resources/' },
      { label: 'All Tools', href: '/tools/' },
    ],
  },
  {
    label: 'Legal',
    links: [
      { label: 'Privacy Policy', href: '/privacy-policy/' },
      { label: 'Terms & Conditions', href: '/terms-and-conditions/' },
      { label: 'Disclaimer', href: '/disclaimer/' },
    ],
  },
];
---

<footer
  class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas)]"
  role="contentinfo"
>
  <div class="wrap-page py-16">
    <!-- Top: Logo + columns -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-6 mb-12">
      <!-- Brand -->
      <div class="col-span-2 sm:col-span-3 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline mb-4" aria-label="LinkedIn Toolkit">
          <img src="/favicon-96x96.png" alt="" width="28" height="28" class="h-7 w-7 rounded-[var(--radius-sm)]" aria-hidden="true" />
          <span class="text-body-sm-strong text-[var(--color-ink)]">LinkedIn Toolkit</span>
        </a>
        <p class="text-caption text-[var(--color-mute)] max-w-[180px] leading-5">
          Free tools for LinkedIn professionals, creators, and job seekers.
        </p>
      </div>

      <!-- Nav columns -->
      {footerColumns.map((col) => (
        <div>
          <h3 class="text-caption-mono uppercase tracking-wider text-[var(--color-mute)] mb-4">
            {col.label}
          </h3>
          <ul class="list-none m-0 p-0 flex flex-col gap-2.5" role="list">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)] no-underline transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="divider mb-6" role="separator" aria-hidden="true"></div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-caption text-[var(--color-mute)] m-0">
        &copy; {currentYear} LinkedIn Toolkit. Not affiliated with LinkedIn.
      </p>
      <nav class="flex items-center gap-4" aria-label="Legal links">
        <a href="/privacy-policy/" class="text-caption text-[var(--color-mute)] hover:text-[var(--color-body)] transition-colors no-underline">Privacy</a>
        <a href="/terms-and-conditions/" class="text-caption text-[var(--color-mute)] hover:text-[var(--color-body)] transition-colors no-underline">Terms</a>
        <a href="/disclaimer/" class="text-caption text-[var(--color-mute)] hover:text-[var(--color-body)] transition-colors no-underline">Disclaimer</a>
      </nav>
    </div>
  </div>
</footer>
