---
const currentYear = new Date().getFullYear();

const footerColumns = [
  {
    label: 'Tools',
    links: [
      { label: 'Text Formatter', href: '/tools/linkedin-text-formatter/' },
      { label: 'Post Preview', href: '/tools/linkedin-post-preview/' },
      { label: 'Character Counter', href: '/tools/linkedin-character-counter/' },
      { label: 'Headline Analyzer', href: '/tools/linkedin-headline-analyzer/' },
      { label: 'Hashtag Generator', href: '/tools/linkedin-hashtag-generator/' },
      { label: 'Emoji Adder', href: '/tools/linkedin-emoji-adder/' },
    ],
  },
  {
    label: 'Templates',
    links: [
      { label: 'Connection Messages', href: '/tools/linkedin-connection-message-templates/' },
      { label: 'About Section', href: '/tools/linkedin-about-section-templates/' },
      { label: 'All Templates', href: '/templates/' },
    ],
  },
  {
    label: 'Guides',
    links: [
      { label: 'Post Formatting', href: '/guides/linkedin-post-formatting/' },
      { label: 'Headline Examples', href: '/guides/linkedin-headline-examples/' },
      { label: 'All Guides', href: '/guides/' },
    ],
  },
  {
    label: 'Site',
    links: [
      { label: 'Resources', href: '/resources/' },
      { label: 'All Tools', href: '/tools/' },
    ],
  },
];
---

<footer
  class="border-t border-[var(--color-hairline)] bg-[var(--color-canvas)]"
  role="contentinfo"
>
  <div class="wrap-page py-16">
    <!-- Top: Logo + columns -->
    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5 mb-12">
      <!-- Brand -->
      <div class="col-span-2 sm:col-span-3 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline mb-4" aria-label="LinkedIn Toolkit">
          <span class="flex h-7 w-7 items-center justify-center rounded-[var(--radius-sm)] bg-[var(--color-ink)]" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <rect x="1" y="1" width="3.5" height="3.5" rx="0.5" fill="white"/>
              <rect x="1" y="6" width="3.5" height="7" rx="0.5" fill="white"/>
              <rect x="6" y="1" width="7" height="3.5" rx="0.5" fill="white" opacity="0.5"/>
              <path d="M6 6.5C6 6.22386 6.22386 6 6.5 6H9C10.6569 6 12 7.34315 12 9C12 10.6569 10.6569 12 9 12H6.5C6.22386 12 6 11.7761 6 11.5V6.5Z" fill="white"/>
            </svg>
          </span>
          <span class="text-body-sm-strong text-[var(--color-ink)]">LinkedIn Toolkit</span>
        </a>
        <p class="text-caption text-[var(--color-mute)] max-w-[180px] leading-5">
          Free tools for LinkedIn professionals, creators, and job seekers.
        </p>
      </div>

      <!-- Nav columns -->
      {footerColumns.map((col) => (
        <div>
          <h3 class="text-caption-mono uppercase tracking-wider text-[var(--color-mute)] mb-4">
            {col.label}
          </h3>
          <ul class="list-none m-0 p-0 flex flex-col gap-2.5" role="list">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)] no-underline transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="divider mb-6" role="separator" aria-hidden="true"></div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3">
      <p class="text-caption text-[var(--color-mute)] m-0">
        &copy; {currentYear} LinkedIn Toolkit. Not affiliated with LinkedIn.
      </p>
      <p class="text-caption text-[var(--color-mute)] m-0">
        Built for LinkedIn professionals.
      </p>
    </div>
  </div>
</footer>
