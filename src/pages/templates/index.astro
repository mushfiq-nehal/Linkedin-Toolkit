---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { templates } from '../../data/templates';
import { tools } from '../../data/tools';
---

<BaseLayout
  title="LinkedIn Templates — Connection Messages, About Sections & More | LinkedIn Toolkit"
  description="Free LinkedIn templates for connection messages, About sections, and more. Copy-ready templates for every professional scenario."
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Templates', url: '/templates/' }]}
>
  <!-- Header -->
  <div class="border-b border-[var(--color-hairline)] bg-[var(--color-canvas)] pt-14 pb-12">
    <div class="wrap-page">
      <span class="text-caption-mono text-[var(--color-mute)] uppercase tracking-wider mb-3 block">Templates</span>
      <h1 class="text-display-lg text-[var(--color-ink)] mb-4 max-w-2xl">
        Copy-ready LinkedIn templates.
      </h1>
      <p class="text-body-lg text-[var(--color-body)] max-w-xl">
        Professionally written templates for connection messages, About sections, and more. Customize and copy in seconds.
      </p>
    </div>
  </div>

  <!-- Templates list -->
  <div class="bg-[var(--color-canvas-soft)]">
    <div class="wrap-page py-16">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 max-w-3xl">
        {templates.map((template) => (
          <a
            href={template.href}
            class="flex flex-col gap-3 p-6 rounded-[var(--radius-md)] bg-[var(--color-canvas)] border border-[var(--color-hairline)] hover:border-[var(--color-hairline-strong)] hover:shadow-[var(--shadow-card-lg)] transition-all no-underline group"
          >
            <div class="flex items-start justify-between gap-4">
              <h2 class="text-body-md-strong text-[var(--color-ink)]">{template.title}</h2>
              <svg class="w-4 h-4 text-[var(--color-mute)] group-hover:text-[var(--color-ink)] transition-colors shrink-0 mt-0.5" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <p class="text-body-sm text-[var(--color-body)] leading-5">{template.description}</p>
            <p class="text-caption-mono text-[var(--color-mute)] italic mt-auto pt-2">"{template.excerpt}"</p>
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Also see tools -->
  <section class="section-padding border-t border-[var(--color-hairline)] bg-[var(--color-canvas)]" aria-labelledby="templates-tools">
    <div class="wrap-page">
      <h2 id="templates-tools" class="text-display-sm text-[var(--color-ink)] mb-2">Use templates with these tools.</h2>
      <p class="text-body-sm text-[var(--color-body)] mb-8">Format, preview, and perfect your content.</p>
      <div class="flex flex-wrap gap-3">
        {tools.filter((t) => ['text-formatter', 'character-counter', 'post-preview'].includes(t.id)).map((tool) => (
          <a
            href={tool.href}
            class="text-body-sm text-[var(--color-body)] hover:text-[var(--color-ink)] bg-[var(--color-canvas-soft)] border border-[var(--color-hairline)] hover:border-[var(--color-hairline-strong)] rounded-full px-4 py-2 no-underline transition-colors"
          >
            {tool.name}
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
