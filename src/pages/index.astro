---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroWithFormatter from '../components/sections/HeroWithFormatter.astro';
import FeaturedTools from '../components/sections/FeaturedTools.astro';
import Benefits from '../components/sections/Benefits.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import FAQ from '../components/sections/FAQ.astro';
import SEOContent from '../components/sections/SEOContent.astro';
import CTA from '../components/sections/CTA.astro';
import { tools } from '../data/tools';

const homepageFAQ = [
  {
    question: 'How do you bold text in a LinkedIn post?',
    answer: 'LinkedIn\'s native post editor does not support bold text. To bold text in a LinkedIn post, use a LinkedIn text formatter tool that converts your text into Unicode bold characters (𝗹𝗶𝗸𝗲 𝘁𝗵𝗶𝘀). Type or paste your text into the LinkedIn Text Formatter on this page, click the 𝗕𝗼𝗹𝗱 button, and copy the result directly into your LinkedIn post or comment.',
  },
  {
    question: 'How do you make text bold in a LinkedIn post?',
    answer: 'To make text bold on LinkedIn, you need to use Unicode bold characters since LinkedIn does not support Markdown or HTML formatting. Use the free LinkedIn Text Formatter above: type your text, select the words you want bold, and click the Bold style. The formatted text copies into LinkedIn posts, headlines, About sections, and comments — and renders correctly on all devices.',
  },
  {
    question: 'How do you format text in a LinkedIn post?',
    answer: 'LinkedIn posts support Unicode text formatting — not Markdown or HTML. You can apply bold, italic, strikethrough, script, and sans-serif styles using a LinkedIn text formatter. On this page, type your post text, select a formatting style (Bold, Italic, etc.), and copy the styled output into LinkedIn. These Unicode characters render correctly across LinkedIn\'s web, iOS, and Android apps.',
  },
  {
    question: 'Where is the LinkedIn text formatter?',
    answer: 'LinkedIn does not have a built-in text formatter. To format text for LinkedIn posts, use a third-party tool like the LinkedIn Text Formatter available at the top of this page. It lets you apply bold, italic, strikethrough, and 10 other Unicode text styles — then copy the result straight into LinkedIn.',
  },
  {
    question: 'Is LinkedIn Toolkit free to use?',
    answer: 'Yes. All core tools are completely free to use with no account required. You can land on any tool page and start using it immediately.',
  },
  {
    question: 'Do I need to create an account?',
    answer: 'No account is required for any of the core tools. Just visit a tool page and start using it right away.',
  },
  {
    question: 'Does LinkedIn Toolkit store my data?',
    answer: 'No. All tools run entirely in your browser. Your text, headlines, and content are never sent to our servers.',
  },
  {
    question: 'What LinkedIn tools are available?',
    answer: 'LinkedIn Toolkit includes a LinkedIn Text Formatter (bold, italic, and 10 Unicode styles), Post Preview, Character Counter, Headline Analyzer, Hashtag Generator, Emoji Adder, Connection Message Templates, and About Section Generator — with more tools planned.',
  },
  {
    question: 'Does LinkedIn allow Unicode text formatting?',
    answer: 'Yes. LinkedIn does not support native Markdown formatting, but Unicode mathematical symbols render as bold, italic, and other styles. These display across all devices and platforms where LinkedIn is available.',
  },
  {
    question: 'Who is LinkedIn Toolkit for?',
    answer: 'LinkedIn Toolkit is built for LinkedIn creators, professionals building their personal brand, job seekers, recruiters, and content marketers who use LinkedIn regularly.',
  },
  {
    question: 'How many hashtags should I use on LinkedIn posts?',
    answer: 'LinkedIn hashtag best practices recommend using 3–5 targeted hashtags per post. Using too many can look spammy and reduce reach. Our LinkedIn Hashtag Generator helps you find the most relevant hashtags by topic, industry, and audience size — so every hashtag you use actually drives discovery.',
  },
  {
    question: 'What makes a great LinkedIn headline?',
    answer: 'A strong LinkedIn headline goes beyond your job title. The best LinkedIn headline examples combine your role, your value proposition, and relevant keywords — all within 220 characters. For example: "Product Designer | Helping SaaS startups ship faster | Ex-Google". Our LinkedIn Headline Analyzer scores your headline and shows you exactly what to improve.',
  },
];

const homepageSEOContent = `
<p>LinkedIn is the world's largest professional network, with over 1 billion members. Standing out requires the right LinkedIn text formatter, headline, and content strategy — not just a polished profile. LinkedIn Toolkit gives you every free tool you need to write better, format smarter, and get noticed.</p>

<h3>LinkedIn text formatter — bold, italic, and more</h3>
<p>LinkedIn's native composer doesn't support bold, italic, or any text formatting. Typing **bold** renders as literal asterisks. The solution is Unicode mathematical alphanumeric symbols — real characters that look like formatting and render correctly on every LinkedIn surface: posts, comments, headlines, About sections, and job descriptions.</p>
<p>Our <a href="/linkedin-text-formatter/">LinkedIn Text Formatter</a> is the fastest free tool to apply bold LinkedIn text, italic, strikethrough, script, and sans-serif styles. Select any word, click a style button, and copy the result straight into LinkedIn. No account. No install. Works on desktop and mobile.</p>

<h3>LinkedIn headline generator and examples</h3>
<p>Your LinkedIn headline is the single most-read line on your entire profile. It appears in search results, connection requests, post notifications, and recruiter searches. A generic job title wastes that space. The best LinkedIn headline examples combine your role, a clear value statement, and searchable keywords — all within the 220-character limit.</p>
<p>Use our <a href="/linkedin-headline-analyzer/">LinkedIn Headline Analyzer</a> to score your current headline for clarity, keyword density, and impact. Whether you need LinkedIn headline ideas for a career pivot, a job search, or building a personal brand, the analyzer gives you a concrete score and specific improvements to make.</p>

<h3>LinkedIn hashtag generator and strategy</h3>
<p>Hashtags on LinkedIn work differently than on Instagram or Twitter. LinkedIn's algorithm uses hashtags to categorize content and surface it to topic followers — but only when used strategically. LinkedIn hashtag best practices in 2026 recommend 3–5 hashtags per post, mixing one high-volume hashtag (1M+ followers) with two or three niche hashtags (10K–100K followers) that closely match your content.</p>
<p>Our <a href="/linkedin-hashtag-generator/">LinkedIn Hashtag Generator</a> recommends hashtags by industry, topic, and audience size. Rather than guessing, you get curated suggestions with follower counts so you can build a hashtag strategy that maximizes reach without looking spammy. Effective LinkedIn hashtag analytics start with knowing which tags your audience actually follows.</p>

<h3>LinkedIn post preview — see before you publish</h3>
<p>LinkedIn collapses posts longer than roughly 210 characters on desktop and 140 on mobile, hiding the rest behind a "see more" button. Your opening hook determines whether anyone reads the rest. Our <a href="/linkedin-post-preview/">LinkedIn Post Preview</a> shows you exactly where that truncation falls so you can craft openings that stop the scroll.</p>

<h3>LinkedIn character counter</h3>
<p>Every LinkedIn field has a strict character limit: posts (3,000), headlines (220), About sections (2,600), and connection messages (300). Exceeding those limits silently truncates your content. Our <a href="/linkedin-character-counter/">LinkedIn Character Counter</a> tracks all four limits simultaneously with real-time progress indicators, so you never accidentally cut off your call to action.</p>

<h3>LinkedIn About section generator</h3>
<p>Your LinkedIn About section is your personal landing page — up to 2,600 characters to tell your professional story, highlight achievements, and include keywords recruiters search for. Our <a href="/linkedin-about-section-templates/">LinkedIn About Generator</a> provides role-specific templates for engineers, product managers, marketers, recruiters, students, and founders — giving you a proven structure you can personalize in minutes.</p>

<h3>Why LinkedIn text formatting matters for engagement</h3>
<p>Formatted LinkedIn posts consistently outperform plain-text posts in reach and engagement. Bold text draws the eye to key points. Structured bullet lists make long posts scannable on mobile. A clear headline-style opening increases the chance someone clicks "see more." Used with discipline — not every other word — LinkedIn text formatting signals that you value your reader's time. That is what LinkedIn Toolkit helps you do.</p>
`;

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'LinkedIn Toolkit',
  url: 'https://linkedintoolkit.com',
  description: 'Free LinkedIn tools for creators, professionals, job seekers, and recruiters.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://linkedintoolkit.com/tools/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const textFormatterSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'LinkedIn Text Formatter',
  description: 'Free LinkedIn text formatter — apply bold, italic, strikethrough, and 10 Unicode text styles to LinkedIn posts. No account required.',
  url: 'https://linkedintoolkit.com/linkedin-text-formatter/',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<BaseLayout
  title="LinkedIn Text Formatter & Free LinkedIn Tools | LinkedIn Toolkit"
  description="Free LinkedIn text formatter — bold, italic & 10 Unicode styles. Plus Headline Analyzer, Hashtag Generator, Post Preview, Character Counter & more. No account needed."
  schema={[websiteSchema, textFormatterSchema]}
  breadcrumbs={[{ name: 'Home', url: '/' }]}
>
  <HeroWithFormatter />

  <FeaturedTools tools={tools} />

  <Benefits />

  <HowItWorks />

  <FAQ items={homepageFAQ} title="Frequently asked questions." />

  <SEOContent
    heading="LinkedIn text formatting, headlines, hashtags, and more."
    content={homepageSEOContent}
  />

  <!-- Internal links to content hubs -->
  <section class="section-padding bg-[var(--color-canvas-soft-2)] border-t border-[var(--color-hairline)]" aria-labelledby="content-hubs-heading">
    <div class="wrap-page">
      <h2 id="content-hubs-heading" class="text-display-md text-[var(--color-ink)] mb-8">Explore more resources.</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { title: 'All Tools', description: 'Browse every LinkedIn tool in one place.', href: '/tools/', icon: '⚙️' },
          { title: 'Guides', description: 'In-depth guides for LinkedIn best practices.', href: '/guides/', icon: '📖' },
          { title: 'Templates', description: 'Ready-to-use message and profile templates.', href: '/templates/', icon: '📋' },
          { title: 'Resources', description: 'Curated resources for LinkedIn growth.', href: '/resources/', icon: '📚' },
        ].map((hub) => (
          <a
            href={hub.href}
            class="flex flex-col gap-3 p-6 rounded-[var(--radius-md)] bg-[var(--color-canvas)] border border-[var(--color-hairline)] hover:border-[var(--color-hairline-strong)] hover:shadow-[var(--shadow-card-md)] transition-all no-underline"
          >
            <span class="text-2xl" aria-hidden="true">{hub.icon}</span>
            <h3 class="text-body-md-strong text-[var(--color-ink)]">{hub.title}</h3>
            <p class="text-body-sm text-[var(--color-body)] leading-5">{hub.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA
    heading="Start using LinkedIn Toolkit today."
    body="Free tools, no account required. Get more from LinkedIn starting now."
    primaryCTA={{ label: 'Browse all tools', href: '/tools/' }}
  />
</BaseLayout>
