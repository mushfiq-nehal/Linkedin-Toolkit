# OpenRouter API key — get yours at https://openrouter.ai/keys
# Used for AI-powered hashtag generation, hook suggestions, and headline rewrites.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenRouter model to use (optional — defaults to the free Nemotron model)
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
